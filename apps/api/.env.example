# Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_ID=

# LLM
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Cron
CRON_SECRET=

# Dashboard session signing (falls back to CRON_SECRET if unset)
SESSION_SECRET=

# Optional: set to "true" to add an LLM one-line insight to summaries
SUMMARY_INSIGHT_ENABLED=false

# App
APP_URL=https://your-app.onrender.com
# Public URL of the Next.js dashboard (used by /login magic links)
DASHBOARD_URL=https://your-app.vercel.app
