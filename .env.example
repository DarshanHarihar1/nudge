# Telegram
TELEGRAM_BOT_TOKEN=        # From @BotFather
TELEGRAM_WEBHOOK_SECRET=   # Random string you generate (32+ chars)
TELEGRAM_ALLOWED_ID=       # Your personal Telegram user ID (get from @userinfobot)

# Database
DATABASE_URL=              # postgresql://postgres:[YOUR-PASSWORD]@db.eujgadmyeqndbtvygumg.supabase.co:5432/postgres

# LLM
GROQ_API_KEY=              # From console.groq.com
OPENROUTER_API_KEY=        # From openrouter.ai (fallback — optional but recommended)

# Cron
CRON_SECRET=               # Random string used to protect /cron/* endpoints

# Dashboard
SESSION_SECRET=            # Signs dashboard session cookies (falls back to CRON_SECRET)
SUMMARY_INSIGHT_ENABLED=false  # "true" adds an optional LLM one-line insight to summaries

# App
APP_URL=                   # Full URL of your Render deployment, e.g. https://nudge.onrender.com
